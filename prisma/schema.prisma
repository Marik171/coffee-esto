datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id                String      @id
  email             String
  phone             String      @default("")
  address           String
  paymentId         String      @default("")
  subtotal          Float
  shippingFee       Float
  totalAmount       Float
  status            String      @default("pending")
  paymentStatus     String      @default("awaiting")
  fulfillmentStatus String      @default("not_fulfilled")
  trackingNumber    String      @default("")
  shippingProvider  String      @default("")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
  customerId        String?
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coffeeId String
  name     String
  quantity Int
  price    Float
}

model Product {
  id           String   @id
  name         String
  category     String
  origin       String
  altitude     String
  varietal     String
  roastLevel   Int
  tastingNotes String
  description  String
  price        Float
  wholesalePrice Float   @default(0.0)
  stock        Int      @default(0)
  imageUrl     String   @default("")
  videoUrl     String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  slug      String   @unique
  label     String
  createdAt DateTime @default(now())
}

model Customer {
  id                String          @id @default(uuid())
  email             String          @unique
  name              String          @default("")
  phone             String          @default("")
  newsOptIn         Boolean         @default(true)
  iyzicoCardUserKey String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  addresses         Address[]
  orders            Order[]
  paymentMethods    PaymentMethod[]
}

model LoginCode {
  id         String    @id @default(uuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email])
}

model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fullName   String
  address    String
  city       String
  zipCode    String
  phone      String   @default("")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
}

// Stores only iyzico's tokenized card reference + display metadata.
// Raw PAN/CVC never touch our database — they're sent straight to iyzico's
// card-storage endpoint and discarded server-side after the token comes back.
model PaymentMethod {
  id              String   @id @default(uuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  cardToken       String
  cardAlias       String   @default("")
  lastFourDigits  String
  cardAssociation String   @default("")
  cardFamily      String   @default("")
  cardBankName    String   @default("")
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([customerId])
}
